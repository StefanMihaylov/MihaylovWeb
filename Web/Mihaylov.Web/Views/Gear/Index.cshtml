@using Mihaylov.Web.Models.Configs
@using Mihaylov.Web.Models.Gear
@model TripGripViewModel

<div class="trip-grid-container mt-4">
    <div class="card shadow-sm border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fa fa-map-marked-alt"></i>Пътешествия</h5>
            <button class="btn btn-light btn-sm trip-btn-add">
                <i class="fa fa-plus"></i> Добави
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="tripTable">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 10%">Година</th>
                            <th>Име</th>
                            <th class="d-none d-md-table-cell">Бележки</th>
                            <th class="d-none d-lg-table-cell">Създаден</th>
                            <th class="text-right">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trip in Model.Trips)
                        {
                            <tr>
                                <td><strong>@trip.Year</strong></td> @* <span class="badge badge-pill badge-primary p-2"> *@                 
                                <td><strong>@trip.Title</strong></td>
                                <td class="d-none d-md-table-cell text-truncate" style="max-width: 250px;">
                                    @trip.Notes
                                </td>
                                <td class="d-none d-lg-table-cell">
                                    <small class="text-muted">@trip.CreatedAt.ToString(ViewConstants.DateFormatSimple)</small>
                                </td>
                                <td class="text-right">
                                    <a class="btn btn-sm btn-outline-info" asp-area="" asp-controller="Gear" asp-action="Trip" asp-route-id="@trip.Id">
                                        <i class="fa fa-eye"></i> Преглед
                                    </a>
                                    <button class="btn btn-sm btn-outline-info trip-btn-edit" data-json='@Json.Serialize(trip)'>
                                        <i class="fa fa-edit"></i> Редактиране
                                    </button>
                                    <a class="btn btn-sm btn-outline-secondary" asp-area="" asp-controller="Gear" asp-action="Clone" asp-route-id="@trip.Id">
                                        <i class="fa fa-copy"></i> Clone
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade trip-modal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="SaveTrip" method="post">
                    <div class="modal-header bg-light">
                        <h5 class="trip-modal-title">Trip Details</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" class="trip-field-id" />

                        <div class="row">
                            <div class="col-md-8 form-group">
                                <label>Title</label>
                                <input type="text" name="Title" class="form-control trip-field-title" required placeholder="e.g. Summer Alps Expedition" />
                            </div>
                            <div class="col-md-4 form-group">
                                <label>Year</label>
                                <input type="number" name="Year" class="form-control trip-field-year" min="1900" max="2100" required />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Notes</label>
                            <textarea name="Notes" class="form-control trip-field-notes" rows="4" placeholder="Notes..."></textarea>
                        </div>

                        <div class="form-group">
                            <label>Record Created</label>
                            <input type="date" name="CreatedAt" class="form-control trip-field-created-text" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-info text-white">Save Trip</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/gear-index.js"></script>
}