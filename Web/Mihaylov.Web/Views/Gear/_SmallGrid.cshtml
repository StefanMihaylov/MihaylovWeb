@using Mihaylov.Web.Models.Gear
@model SmallGridViewModel

@{
    // Generate a unique string for this specific grid instance (e.g., "Grid_Categories")
    var gridId = "grid_" + Model.Title.Replace(" ", "");
}

<div id="@gridId" class="generic-grid-container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">@Model.Title</h4>
            <button class="btn btn-primary btn-sm btn-generic-add">
                <i class="fa fa-plus"></i> Add
            </button>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>Name</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-info btn-generic-edit" 
                                        data-id="@item.Id" 
                                        data-name="@item.Name">Edit</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade generic-modal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form action="@Model.SaveActionUrl" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">@Model.Title</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" class="field-id" />
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="Name" class="field-name form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>