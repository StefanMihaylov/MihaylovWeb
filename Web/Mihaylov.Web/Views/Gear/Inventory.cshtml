@using Mihaylov.Api.Gear.Client
@using Mihaylov.Web.Models.Configs
@using Mihaylov.Web.Models.Gear
@model InventoryGridViewModel

<div class="inventory-grid-container mt-4">
    <div class="card shadow border-dark">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fa fa-boxes"></i> Екипировка - @Model.Items.Count() бр.</h5>
            <span class="align-items-end radio-container">
                
                <span class="btn-group btn-group-toggle btn-group-sm mr-3" data-toggle="buttons">
                    <label class="btn btn-outline-light @(!Model.ActiveOnly ? "active" : "")">
                        <input type="radio" name="inventoryFilter" id="inventory-filter-all" autocomplete="off" @(!Model.ActiveOnly ? "checked" : "")>
                        All Items
                    </label>
                    <label class="btn btn-outline-light @(Model.ActiveOnly ? "active" : "")">
                        <input type="radio" name="inventoryFilter" id="inventory-filter-active" autocomplete="off" @(Model.ActiveOnly ? "checked" : "")>
                        <i class="fa fa-box-open mr-1"></i> Active
                    </label>
                </span>

                <button class="btn btn-light btn-sm inventory-btn-add">
                    <i class="fa fa-plus"></i> Add Item
                </button>
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="inventoryTable">
                    <thead class="thead-light">
                        <tr>
                            <th>Име</th>
                            <th width="30%">Описание</th>
                            <th>Категория</th>
                            <th>Магазин</th>
                            <th>Марка</th>
                            <th>Цена</th>
                            <th>Покупка</th>
                            <th>Статус</th>

                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            string rowClass = item.ItemStatus switch
                            {
                                ItemStatus.Ignored => "table-info",
                                ItemStatus.Active => string.Empty,
                                _ => "table-warning"
                            };

                            if (!string.IsNullOrEmpty(rowClass))
                            {
                                rowClass += " inventory-inactive-row";
                            }

                            <tr class="@rowClass">
                                <td>@item.Name</td>
                                <td>
                                    @item.Description

                                    @if (item.KitContents != null && item.KitContents.Any())
                                    {
                                        <div class="inventory-kit-row">
                                            <i class="fas fa-boxes text-info mr-1" style="font-size: 0.75rem;" title="Kit Contents"></i>
                                            @string.Join(" • ", item.KitContents.Select(x => x.Name))
                                        </div>
                                    }
                                </td>
                                <td>@item.Category</td>
                                <td>@item.Shop</td>
                                <td>@item.Brand</td>
                                <td>@item.Price?.ToString("#.00") @item.Currency</td>
                                <td>@item.PurchaseDate?.ToString(ViewConstants.DateFormatSimple)</td>
                                <td><span class="badge badge-info">@item.ItemStatus</span></td>

                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary inventory-btn-edit"
                                            data-id="@item.Id"
                                            data-json='@Json.Serialize(item)'>
                                        <i class="fa fa-edit">Редактиране</i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade inventory-modal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <form asp-action="SaveInventory" method="post">
                    <div class="modal-header bg-light">
                        <h5 class="inventory-modal-title">Inventory Item</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" class="inventory-field-id" />

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Име</label>
                                <input type="text" name="Name" class="form-control inventory-field-name" required />
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Категория</label>
                                @Html.DropDownList("CategoryId", Model.Categories, ViewConstants.DefaultDropDownValue, new { @class = "short-width form-control inventory-field-category", style = "min-width: 200px;" })
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Описание</label>
                            <textarea name="Description" class="form-control inventory-field-description" rows="2"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-3 form-group">
                                <label>Магазин</label>
                                @Html.DropDownList("ShopId", Model.Shops, ViewConstants.DefaultDropDownValue, new { @class = "short-width form-control inventory-field-shop", style = "min-width: 100px;" })
                            </div>
                            <div class="col-md-3 form-group">
                                <label>Марка</label>
                                @Html.DropDownList("BrandId", Model.Brands, ViewConstants.DefaultDropDownValue, new { @class = "short-width form-control inventory-field-brand", style = "min-width: 100px;" })
                            </div>
                            <div class="col-md-3 form-group">
                                <label>Price</label>
                                <input type="number" step="0.01" name="Price" class="form-control inventory-field-price" />
                            </div>
                            <div class="col-md-3 form-group">
                                <label>Валута</label>
                                @Html.DropDownList("CurrencyId", Model.Currencies, new { @class = "short-width form-control inventory-field-currency", style = "min-width: 100px;" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3 form-group">
                                <label>Покупка</label>
                                <input type="date" name="PurchaseDate" class="form-control inventory-field-purchasedate" />
                            </div>
                            <div class="col-md-3 form-group">
                                <label>Статус</label>
                                @Html.DropDownList("ItemStatus", Model.Statuses, new { @class = "short-width form-control inventory-field-item-status", style = "min-width: 100px;" })
                            </div>
                            <div class="col-md-3 form-group">
                            </div>
                            <div class="col-md-3 form-group">
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12">
                                <label class="font-weight-bold"><i class="fa fa-briefcase-medical text-danger"></i> Kit Contents</label>
                                <table class="table table-sm table-bordered" id="inventory-kit-table">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Item Name</th>
                                            <th style="width: 50px"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="inventory-kit-body">
                                    </tbody>
                                </table>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="inventory-btn-add-kit">
                                    <i class="fa fa-plus"></i> Add Kit Item
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
            <table class="d-none">
                <tr id="kit-row-template">
                    <td>
                        <input type="text" name="KitContents[].Name" class="form-control form-control-sm kit-item-input" placeholder="Element..." required />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-link text-danger remove-kit-row"><i class="fa fa-trash"></i></button>
                    </td>
                </tr>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/gear-inventory.js"></script>
}